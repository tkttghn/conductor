#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/pointing.h>

&mt {
    flavor = "balanced";
    tapping-term-ms = <150>;
    quick-tap-ms = <200>;
};

&lt {
    tapping-term-ms = <150>;
    quick-tap-ms = <200>;
    flavor = "balanced";
};

/ {
    combos {
        compatible = "zmk,combos";

        combo_scroll_MB3 {
            bindings = <&lt_mouse 5 MK_MB3>;
            key-positions = <17 18>;
            timeout-ms = <25>;
        };

        combo_pair {
            bindings = <&mkp MB5>;
            key-positions = <0 10 20>;
            timeout-ms = <50>;
        };

        combo_boot {
            bindings = <&bootloader>;
            key-positions = <8 24 4>;
            timeout-ms = <50>;
        };

        combo_mb1 {
            timeout-ms = <25>;
            bindings = <&mkp MB1>;
            key-positions = <16 17>;
        };

        combo_mb2 {
            timeout-ms = <25>;
            bindings = <&mkp MB2>;
            key-positions = <18 19>;
        };
    };

    macros {
        mc_bt_SEL_mac: mc_bt_SEL_mac {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&bt BT_SEL 0>     // プロファイル0を選択して接続試行
                , <&macro_wait_time 200>    // 200ms 待機
                , <&to 0>            // レイヤー0へ移行
                ;
        };

        mc_bt_SEL_ipad: mc_bt_SEL_ipad {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&bt BT_SEL 1>     // プロファイル1を選択して接続試行
                , <&macro_wait_time 200>    // 200ms 待機
                , <&to 0>            // レイヤー0へ移行
                ;
        };

        mc_bt_SEL_win: mc_bt_SEL_win {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&bt BT_SEL 3>     // プロファイル3を選択して接続試行
                , <&macro_wait_time 200>    // 200ms 待機
                , <&to 1>            // レイヤー1へ移行
                ;
        };

        // Emacs風 C-k (行末まで切り取り)
        emacs_kill_line: emacs_kill_line {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>;
            tap-ms = <10>;
            bindings
                = <&macro_press &kp LSHFT>
                , <&macro_tap &kp END>
                , <&macro_release &kp LSHFT>
                , <&macro_wait_time 20> // 切り取り前に少し待機（安定用）
                , <&macro_press &kp LCTRL>
                , <&macro_tap &kp X>
                , <&macro_release &kp LCTRL>
                ;
        };
    };

    behaviors {
        // マウスボタンを対象とするレイヤータップの定義
        lt_mouse: lt_mouse {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            // 1つ目の引数にレイヤー(&mo)、2つ目にマウスクリック(&mkp)を指定可能にする
            bindings = <&mo>, <&mkp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        mac_default_layer {
            bindings = <
                &kp Q             &kp L         &kp U             &kp COMMA           &kp DOT                                        &kp F      &kp W  &kp R  &kp Y     &kp P
                &lt 9 E           &kp I         &kp A             &kp O               &kp MINUS                                      &kp K      &kp T  &kp N  &kp S     &kp H
                &mt LEFT_SHIFT Z  &kp X         &kp C             &kp V               &kp SEMI                                       &kp G      &kp D  &kp M  &kp J     &mt RIGHT_SHIFT B
                &kp LGUI          &kp LEFT_ALT  &kp LEFT_CONTROL  &mt LEFT_GUI LANG2  &lt 2 SPACE  &lt 5 LANG1  &mt RIGHT_SHIFT TAB  &lt 7 RET                &kp CAPS  &kp ESC
            >;

            sensor-bindings = <&inc_dec_kp PG_UP PG_DN>;
        };

        win_default_layer {
            bindings = <
                &kp Q             &kp L         &kp U         &kp COMMA           &kp DOT                                        &kp F       &kp W  &kp R  &kp Y     &kp P
                &lt 10 E          &kp I         &kp A         &kp O               &kp MINUS                                      &kp K       &kp T  &kp N  &kp S     &kp H
                &mt LEFT_SHIFT Z  &kp X         &kp C         &kp V               &kp SEMI                                       &kp G       &kp D  &kp M  &kp J     &mt LEFT_SHIFT B
                &kp LEFT_CONTROL  &kp LEFT_ALT  &kp LEFT_GUI  &mt LEFT_ALT LANG2  &lt 2 SPACE  &lt 6 LANG1  &mt RIGHT_SHIFT TAB  &lt 8 RET                &kp CAPS  &kp ESC
            >;
        };

        number_layer {
            bindings = <
                &kp N1          &kp N2      &kp N3      &kp N4      &kp N5                        &kp N6     &kp N7    &kp N8    &kp N9    &kp N0
                &kp BACKSLASH   &kp LS(N2)  &kp LS(N8)  &kp LS(N1)  &kp LS(FSLH)                  &kp EQUAL  &mkp MB1  &mkp MB3  &mkp MB2  &trans
                &kp LEFT_SHIFT  &trans      &kp LS(N9)  &kp LS(N0)  &kp LS(N3)                    &kp GRAVE  &kp SQT   &kp LBKT  &kp RBKT  &mt RIGHT_SHIFT FSLH
                &trans          &trans      &trans      &trans      &trans        &trans  &trans  &trans                         &trans    &trans
            >;
        };

        layer_3 {
            bindings = <
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans
            >;
        };

        mouse_layer {
            bindings = <
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans
            >;
        };

        mac_scroll_layer {
            bindings = <
                &kp C_BRI_DEC   &kp C_BRI_INC  &none       &kp LG(MINUS)          &kp LS(LG(EQUAL))                     &mkp MB5           &none              &none  &none              &none
                &kp C_VOL_DN    &kp C_VOL_UP   &kp C_MUTE  &kp LA(LC(LG(RIGHT)))  &none                                 &mkp MB4           &none              &none  &kp LA(LC(LG(L)))  &trans
                &kp LEFT_SHIFT  &none          &none       &none                  &kp LA(LC(LG(LEFT)))                  &kp LA(LC(LG(N)))  &kp LA(LC(LG(M)))  &none  &none              &kp RIGHT_SHIFT
                &trans          &trans         &trans      &trans                 &mo 11                &trans  &trans  &trans                                       &trans             &trans
            >;
        };

        win_scroll_layer {
            bindings = <
                &kp C_BRI_DEC   &kp C_BRI_INC  &none       &kp LG(MINUS)          &kp LS(LG(EQUAL))                     &mkp MB5           &none              &none  &none              &none
                &kp C_VOL_DN    &kp C_VOL_UP   &kp C_MUTE  &kp LG(RIGHT)          &none                                 &mkp MB4           &none              &none  &kp LA(LC(LG(L)))  &trans
                &kp LEFT_SHIFT  &none          &none       &none                  &kp LG(LEFT)                          &kp LG(LS(LEFT))   &kp LG(UP)         &none  &none              &kp RIGHT_SHIFT
                &trans          &trans         &trans      &trans                 &mo 11                &trans  &trans  &trans                                       &trans             &trans
            >;
