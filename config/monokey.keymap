        mac_fanc_layer {
            bindings = <
                &kp F1          &kp F2        &kp F3             &kp F4         &kp F5                          &kp F6    &kp F7    &kp F8    &kp F9     &kp F10
                &kp F11         &kp F12       &kp LC(F)          &none          &none                           &kp BSPC  &mkp MB1  &kp UP    &mkp MB2   &none
                &kp LEFT_SHIFT  &kp LC(LEFT)  &kp LA(LC(LG(N)))  &kp LC(RIGHT)  &kp LS(LG(N4))                  &kp DEL   &kp LEFT  &kp DOWN  &kp RIGHT  &kp RIGHT_SHIFT
                &trans          &trans        &trans             &trans         &trans          &trans  &trans  &trans                        &trans     &trans
            >;
        };

        win_fanc_layer {
            bindings = <
                &kp F1          &kp F2        &kp F3        &kp F4         &kp F5                         &kp F6    &kp F7    &kp F8    &kp F9     &kp F10
                &kp F11         &kp F12       &kp LG(UP)    &none          &none                          &kp BSPC  &mkp MB1  &kp UP    &mkp MB2   &none
                &kp LEFT_SHIFT  &kp LG(LEFT)  &kp LG(DOWN)  &kp LG(RIGHT)  &kp LS(LG(S))                  &kp DEL   &kp LEFT  &kp DOWN  &kp RIGHT  &kp RIGHT_SHIFT
                &trans          &trans        &trans        &trans         &trans         &trans  &trans  &trans                        &trans     &trans
            >;
        };

        mac_emacs_layer {
            bindings = <
                &trans  &trans     &kp LC(E)    &trans     &trans                    &trans    &trans     &trans     &trans     &kp UP
                &trans  &kp LC(A)  &kp DEL      &kp RIGHT  &trans                    &kp BSPC  &kp LC(J)  &kp LC(K)  &kp LC(L)  &kp LC(SEMI)
                &trans  &trans     &trans       &trans     &kp LEFT                  &kp DOWN  &kp RET    &trans     &trans     &trans
                &trans  &trans     &trans       &trans     &trans    &trans  &trans  &trans                          &trans     &trans
            >;
        };

        win_emacs_layer {
            bindings = <
                &trans  &trans    &kp END  &trans     &trans                    &trans    &trans   &trans            &trans  &kp UP
                &trans  &kp HOME  &kp DEL  &kp RIGHT  &trans                    &kp BSPC  &kp F6   &emacs_kill_line  &kp F9  &kp F10
