#include "monokey.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/input_transform.h>

&default_transform {
    col-offset = <6>;
};

&xiao_serial { status = "disabled"; };

&kscan0 {
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
            , <&gpio0 10 GPIO_ACTIVE_HIGH>
            ;
};

/* NFC pins as GPIO (replaces CONFIG_NFCT_PINS_AS_GPIOS=y) */
&uicr {
    nfct-pins-as-gpios;
};

// 非マウスキーでAML解除
&zip_temp_layer {
    excluded-positions = <
        17 // K
        18 // L
    >;
    require-prior-idle-ms = <300>;
    // タイピング後300ms経過でAMLが発動可能（100msだとsplit BLE通信ラグが顕著、750msだと反応鈍い）
    require-prior-motion = <50>;
    // モーション閾値50（元の値）: motion下げ(30)はAML発動頻度を増やしsplit BLEラグを悪化させると Codex が指摘、元に戻す
};


/ {
    /* Reduce horizontal scroll sensitivity to prevent accidental triggering */
    hwheel_scaler: hwheel_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_HWHEEL>;
        track-remainders;
    };

    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;

        /* ベース: オートマウスレイヤー (AML)
         * トラックボール操作時にレイヤー4 (MOUSE) を自動有効化
         * 60000ms (60秒) のタイムアウトで自動解除 */
        input-processors = <&zip_temp_layer 4 60000>;

        /* スクロールレイヤー: レイヤー5 (SCROLL) がアクティブ時
         * XY移動をスクロールホイールに変換
         * スクロール速度をスケーリング (1/8) で調整 */
        scroll_layer {
            layers = <5>;
            input-processors = <&zip_xy_to_scroll_mapper &zip_scroll_transform INPUT_TRANSFORM_Y_INVERT &zip_scroll_scaler 1 16 &zip_scroll_scaler 1 2 &studio_scroll_scaler &hwheel_scaler 1 2>;
        };

        /* 精密モード: レイヤー12 (PRECISION) がアクティブ時、
         * カーソル移動を Studio から動的に変更可能な倍率でスケールダウン。
         * 既定 1/4。Conductor Studio の Trackball タブで変更可能。
         * トグルキー（&tog 12）で ON/OFF。 */
        precision_layer {
            layers = <12>;
            input-processors = <&studio_pointer_scaler>;
        };
    };

    chg_stat: chg_stat {
        compatible = "custom,chg-stat";
        /* Xiao BLE の充電検知ピン P0.17 (Low = 充電中, High = 完了/未接続) */
        gpios = <&gpio0 17 GPIO_ACTIVE_LOW>;
        status = "okay";
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        cpi = <800>;
        force-awake;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};
